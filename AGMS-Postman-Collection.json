{
  "info": {
    "name": "AGMS System — Full API Collection",
    "description": "Complete Postman collection for the Agricultural Management System (AGMS).\n\nAll API requests go through the Gateway on port 8080.\n\n--- HOW TO GET YOUR TOKEN ---\n1. Run '0. AGMS Login' first — it calls POST /auth/login on the gateway\n2. Your AGMS JWT is automatically saved to the {{jwt_token}} variable\n3. All other requests use it automatically via the collection-level Bearer auth\n\nDO NOT use the IoT platform token for gateway requests — it will always return 401.\n\nStartup order:\n1. eureka-server (8761)\n2. config-server (8888)\n3. zone-service, sensor-service, automation-service, crop-service\n4. api-gateway (8080)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "agms-collection-v1"
  },
  "variable": [
    { "key": "gateway_url",   "value": "http://localhost:8080",                 "type": "string" },
    { "key": "iot_base_url",  "value": "http://104.211.95.241:8080/api",        "type": "string" },
    { "key": "jwt_token",     "value": "",                                       "type": "string", "description": "AGMS JWT — auto-set by the '0. AGMS Login' request. DO NOT paste an IoT token here." },
    { "key": "iot_token",     "value": "",                                       "type": "string", "description": "IoT platform Bearer token (auto-set by IoT Login request)" },
    { "key": "zone_id",       "value": "1",                                      "type": "string" },
    { "key": "sensor_device", "value": "6dd1b80c-4a05-4ec0-a371-f7782774435a",  "type": "string" },
    { "key": "crop_id",       "value": "1",                                      "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "0. AGMS Login — Run This First!",
      "description": "Get an AGMS JWT from the gateway. Run this before any other request. The token is saved automatically to {{jwt_token}}.",
      "item": [
        {
          "name": "AGMS Login (get gateway JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login successful', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "pm.test('AGMS token received', () => pm.expect(json.token).to.be.a('string'));",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('jwt_token', json.token);",
                  "  console.log('✅ AGMS JWT saved to {{jwt_token}}. All other requests are now authorized.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{gateway_url}}/auth/login", "host": ["{{gateway_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"sampath\",\n  \"password\": \"your-iot-password-here\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Validates credentials against the external IoT platform, then returns an AGMS-signed JWT valid for 24 hours.\n\nReplace the username/password with your actual IoT platform credentials."
          },
          "response": []
        }
      ]
    },
    {
      "name": "1. IoT Auth APIs (Direct — no Gateway JWT needed)",
      "description": "Calls directly to the external IoT platform. No AGMS JWT required.",
      "item": [
        {
          "name": "Register IoT User",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{iot_base_url}}/auth/register", "host": ["{{iot_base_url}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"testpassword\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": []
        },
        {
          "name": "Login IoT User (IoT token — NOT for gateway)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('iot_token', json.token); }",
                  "pm.test('Login successful', () => pm.response.to.have.status(200));",
                  "pm.test('Token received', () => pm.expect(json.token).to.be.a('string'));",
                  "console.log('ℹ️ This is the IoT platform token. Use {{iot_token}} for IoT API calls only. For gateway API calls, use {{jwt_token}} from the AGMS Login request.');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{iot_base_url}}/auth/login", "host": ["{{iot_base_url}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"testpassword\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": []
        },
        {
          "name": "Refresh IoT Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{iot_base_url}}/auth/refresh", "host": ["{{iot_base_url}}"], "path": ["auth", "refresh"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"PASTE_REFRESH_TOKEN_HERE\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": []
        },
        {
          "name": "Get IoT Devices",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{iot_token}}" }],
            "url": { "raw": "{{iot_base_url}}/devices", "host": ["{{iot_base_url}}"], "path": ["devices"] }
          },
          "response": []
        },
        {
          "name": "Create IoT Device",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{iot_token}}" }
            ],
            "url": { "raw": "{{iot_base_url}}/devices", "host": ["{{iot_base_url}}"], "path": ["devices"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceName\": \"GreenZone-Sensor-1\",\n  \"deviceType\": \"TEMPERATURE_SENSOR\",\n  \"location\": \"Greenhouse A\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": []
        }
      ]
    },
