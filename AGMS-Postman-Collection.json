              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{gateway_url}}/api/zones", "host": ["{{gateway_url}}"], "path": ["api", "zones"] }
          },
          "response": []
        },
        {
          "name": "Invalid Token — Expect 401",
