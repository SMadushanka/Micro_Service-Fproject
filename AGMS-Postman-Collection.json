    {
      "name": "6. JWT Security Tests",
      "description": "Verify gateway authentication behaviour.",
      "item": [
        {
          "name": "No Token — Expect 401",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 401', () => pm.response.to.have.status(401));"
